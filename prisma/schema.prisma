generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  role      UserRole @default(USER)
  password  String
  firstName String
  lastName  String

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Movie {
  id                Int          @id @default(autoincrement())
  title             String
  description       String
  posterImageUrl    String
  durationInMinutes Int
  genres            MovieGenre[]
  showtimes         Showtime[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([genres(ops: ArrayOps)], type: Gin)
}

model Showtime {
  id           Int           @id @default(autoincrement())
  movieId      Int
  auditoriumId Int
  startsAt DateTime
  reservations Reservation[]
  reservedSeats ReservedSeat[]

  movie      Movie      @relation(fields: [movieId], references: [id])
  auditorium Auditorium @relation(fields: [auditoriumId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auditorium {
  id        Int        @id @default(autoincrement())
  name      String
  showtimes Showtime[]
  seats     Seat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seat {
  id           Int           @id @default(autoincrement())
  auditoriumId Int
  tier         SeatTier
  row          Int
  order        Int
  reservations ReservedSeat[]

  auditorium Auditorium @relation(fields: [auditoriumId], references: [id])

  @@unique([auditoriumId, row, order])
}

model ReservedSeat {
  reservationId Int
  seatId Int
  showtimeId Int

  reservation Reservation @relation(fields: [reservationId], references: [id])
  seat        Seat        @relation(fields: [seatId], references: [id])
  showtime    Showtime    @relation(fields: [showtimeId], references: [id])

  @@id([reservationId, seatId])
  @@unique([seatId, showtimeId])
}

model Reservation {
  id         Int               @id @default(autoincrement())
  userId     Int
  showtimeId Int
  paymentId  Int               @unique

  user User @relation(fields: [userId], references: [id])
  showtime Showtime @relation(fields: [showtimeId], references: [id])
  payment  Payment  @relation(fields: [paymentId], references: [id])
  reservedSeats    ReservedSeat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id Int @id @default(autoincrement())

  amount      Int
  status      PaymentStatus
  currency    Currency
  reservation Reservation?
}

enum Currency {
  EUR
  USD
  CZK
  CHF
  TRY
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SeatTier {
  REGULAR
  DISABLED
  PREMIUM
  VIP
}

enum MovieGenre {
  ACTION
  ADVENTURE
  COMEDY
  DRAMA
  HORROR
  ROMANCE
  SCIFI
}
