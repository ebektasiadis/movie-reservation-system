generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  role UserRole @default(USER)
  password String
  firstName String
  lastName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Movie {
  id Int @id @default(autoincrement())
  title String
  description String
  posterImageUrl String
  durationInMinutes Int
  genres MovieGenre[]
  showtimes Showtime[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([genres(ops: ArrayOps)], type: Gin)
}

model Showtime {
  id Int @id @default(autoincrement())
  movieId Int
  auditoriumId Int
  reservations Reservation[]

  movie Movie @relation(fields: [movieId], references: [id])
  auditorium Auditorium @relation(fields: [auditoriumId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auditorium {
  id Int @id @default(autoincrement())
  name String
  showtimes Showtime[]
  seats Seat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seat {
  id Int @id @default(autoincrement())
  auditoriumId Int
  tier SeatTier
  row Int
  order Int
  reservations Reservation[]

  auditorium Auditorium @relation(fields: [auditoriumId], references: [id])
}

model Reservation {
  id Int @id @default(autoincrement())
  showtimeId Int
  status ReservationStatus

  showtime Showtime @relation(fields: [showtimeId], references: [id])
  seats Seat[]

  totalAmountInEuros Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

enum ReservationStatus {
  OK
  CANCELLED
}

enum SeatTier {
  REGULAR
  DISABLED
  PREMIUM
  VIP
}

enum MovieGenre {
  ACTION
  ADVENTURE
  COMEDY
  DRAMA
  HORROR
  ROMANCE
  SCIFI
}